# ============================================================
# FELLOWMART — .gitignore
# ============================================================

# ── Dependencies ────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ────────────────────────────────────
/.next/
/out/
/build

# ── Environment & Secrets (NEVER commit these) ───────────────
.env
.env.*
!.env.local.example      # safe — template only, no real values

# ── Supabase CLI temp files ──────────────────────────────────
supabase/.temp/
supabase/.branches/

# ── Seed file (may contain plain-text credentials) ──────────
supabase/seed.sql

# ── Certificates & Keys ─────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt

# ── Logs ────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS & Editor artifacts ────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json   # safe to share extension recommendations
.idea/

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel / Cloudflare deployment ───────────────────────────
.vercel
.wrangler/

# ── Testing & Coverage ───────────────────────────────────────
/coverage
